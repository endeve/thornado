## Makefile definitions for Frontier with AMD LLVM compiler

C       = CC
FORTRAN = ftn
FLINKER = ftn -flto-partitions=16

DEBUG    = -g -O0 -fsanitize=address,undefined
OPTIMIZE = -g -O3

SUFFIX_f90 =

MDEFS =
PP    = -D

ifeq ($(USE_OMP),TRUE)
  OPENMP = -fopenmp
else ifeq ($(USE_OMP_OL),TRUE)
  OPENMP = -fopenmp
else
  OPENMP = -fno-openmp
endif

ifeq ($(USE_OACC),TRUE)
  OPENACC =
endif

INCLUDE_CUDA     =
INCLUDE_HDF5     = -I$(OLCF_HDF5_ROOT)/include
INCLUDE_LAPACK   =
INCLUDE_MAGMA    = -I$(OLCF_MAGMA_ROOT)/include
INCLUDE_PETSC    =
INCLUDE_ROCM     = -I$(ROCM_PATH)/include -I$(ROCM_PATH)/llvm/include/hipfort/amdgcn

LIBRARIES_CUDA     =
LIBRARIES_HDF5     = -L$(OLCF_HDF5_ROOT)/lib -lhdf5_fortran -lhdf5
LIBRARIES_LAPACK   =
LIBRARIES_MAGMA    = -L$(OLCF_MAGMA_ROOT)/lib -lmagma
LIBRARIES_PETSC    =
LIBRARIES_ROCM     = -L$(ROCM_PATH)/lib -lrocsparse -lrocsolver -lrocblas -lhipblas -lhipsparse -lamdhip64 -L$(ROCM_PATH)/llvm/lib -lhipfort-amdgcn
